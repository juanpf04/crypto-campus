{
  "name": "crypto-campus",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "pnpm --filter nextjs run dev",
    "dev:hardhat": "node scripts/dev.mjs --hardhat",
    "dev:new": "node scripts/dev.mjs --new",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:push": "pnpm --filter nextjs run db:push",
    "db:reset": "pnpm --filter nextjs run db:reset",
    "db:generate": "pnpm --filter nextjs run db:generate",
    "db:studio": "pnpm --filter nextjs run db:studio",
    "db:seed": "node scripts/seed.mjs",
    "db:doctor": "node packages/nextjs/scripts/db-doctor.mjs",
    "db:seed:admin": "node packages/nextjs/scripts/seed-admin.mjs",
    "db:seed:librarian": "node packages/nextjs/scripts/seed-librarian.mjs",
    "db:seed:academic": "node packages/nextjs/scripts/seed-academic.mjs",
    "db:seed:products": "node packages/nextjs/scripts/seed-products.mjs",
    "db:seed:badges": "node packages/nextjs/scripts/seed-badges.mjs",
    "db:seed:library": "node packages/nextjs/scripts/seed-library.mjs",
    "db:seed:rooms": "node packages/nextjs/scripts/seed-rooms.mjs",
    "db:seed:printers": "node packages/nextjs/scripts/seed-printers.mjs",
    "db:seed:historical": "node packages/nextjs/scripts/seed-historical.mjs",
    "reset:chain": "node scripts/reset-chain.mjs",
    "reset:all": "pnpm reset:chain && pnpm db:reset",
    "start": "pnpm --filter nextjs run start",
    "build": "pnpm --filter nextjs run build",
    "compile": "pnpm --filter hardhat run compile",
    "deploy": "pnpm --filter hardhat run deploy",
    "test": "pnpm --filter hardhat run test",
    "lint": "pnpm --filter nextjs run lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": "10.33.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.24.0",
      "hono": "^4.12.4",
      "@hono/node-server": "^1.19.10",
      "flat-cache>flatted": "^3.4.2",
      "micromatch>picomatch": "^2.3.2",
      "anymatch>picomatch": "^2.3.2",
      "tinyglobby>picomatch": "^4.0.4",
      "socket.io-parser": "^4.2.6",
      "h3": "^1.15.6",
      "defu": "^6.1.5",
      "effect": "^3.20.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
