generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  PROFESSOR
  LIBRARIAN
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         Role     @default(STUDENT)
  address      String   @unique   // wallet generada invisiblemente
  encryptedKey String             // clave privada cifrada con AES-256-GCM
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  enrollments       Enrollment[]
  printLogs         PrintLog[]
  loans             Loan[]
  orders            Order[]
  orderBatches      OrderBatch[]
  cart              Cart?
  topupSimulations  CardTopupSimulation[]
  paymentLogs       PaymentSimulationLog[]
  roomBookings      RoomBooking[]
  badgeAwards       BadgeAward[]
  awardedBadgesTo   BadgeAward[]     @relation("AwardedBy")
  badgeTypesCreated BadgeType[]      @relation("BadgeTypeCreator")
  tasksCreated      Task[]           @relation("TaskCreator")
  rewardsCreated    Reward[]         @relation("RewardCreator")
  rewardRedemptions RewardRedemption[]
  subjectOfferings  SubjectOffering[] @relation("OfferingProfessor")
}

// ─────────────────────────────────────────────────────────────
// ASIGNATURAS Y MATRÍCULAS
// ─────────────────────────────────────────────────────────────

model Subject {
  id        String @id @default(cuid())
  name      String // "Fundamentos de Aplicaciones en la Red"
  code      String @unique // "FAL"

  offerings SubjectOffering[]
}

// Una "oferta" es una asignatura impartida por un profesor a un grupo concreto
model SubjectOffering {
  id           String   @id @default(cuid())
  subjectId    String
  professorId  String
  group        String   // "2ºE", "2ºA"
  academicYear String   // "2024-2025"

  subject     Subject   @relation(fields: [subjectId], references: [id])
  professor   User      @relation("OfferingProfessor", fields: [professorId], references: [id])
  enrollments Enrollment[]
  badgeTypes  BadgeType[]

  @@unique([subjectId, professorId, group, academicYear])
}

// Alumno matriculado en una asignatura+grupo
model Enrollment {
  id                String   @id @default(cuid())
  userId            String
  subjectOfferingId String
  enrolledAt        DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  subjectOffering SubjectOffering @relation(fields: [subjectOfferingId], references: [id])

  @@unique([userId, subjectOfferingId])
}

// ─────────────────────────────────────────────────────────────
// INSIGNIAS (BADGES)
// ─────────────────────────────────────────────────────────────

// Tipo de insignia. tokenId = ID en BadgeSystem (ERC-1155).
// Vinculado a una SubjectOffering para restringir el acceso por grupo.
model BadgeType {
  id                String   @id @default(cuid())
  tokenId           Int      @unique  // ID en el contrato BadgeSystem
  name              String
  description       String
  subjectOfferingId String
  creatorId         String
  txHash            String
  createdAt         DateTime @default(now())

  subjectOffering SubjectOffering @relation(fields: [subjectOfferingId], references: [id])
  creator         User            @relation("BadgeTypeCreator", fields: [creatorId], references: [id])
  tasks           Task[]
  rewards         Reward[]
  awards          BadgeAward[]
}

// Tarea creada por un profesor. taskId = ID en BadgeSystem.
model Task {
  id           String   @id @default(cuid())
  taskId       Int      @unique  // ID en el contrato BadgeSystem
  name         String
  description  String
  badgeTypeId  String
  rewardAmount Int
  active       Boolean  @default(true)
  creatorId    String
  txHash       String
  createdAt    DateTime @default(now())

  badgeType BadgeType @relation(fields: [badgeTypeId], references: [id])
  creator   User      @relation("TaskCreator", fields: [creatorId], references: [id])
  awards    BadgeAward[]
}

// Log de insignias entregadas. Un registro por cada awardBadge ejecutado.
model BadgeAward {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  badgeTypeId String
  awardedById String
  txHash      String
  awardedAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  task      Task      @relation(fields: [taskId], references: [id])
  badgeType BadgeType @relation(fields: [badgeTypeId], references: [id])
  awardedBy User      @relation("AwardedBy", fields: [awardedById], references: [id])

  @@unique([userId, taskId]) // un alumno solo puede ganar cada tarea una vez
}

// Recompensa canjeable con insignias. rewardId = ID en BadgeSystem.
model Reward {
  id          String   @id @default(cuid())
  rewardId    Int      @unique  // ID en el contrato BadgeSystem
  name        String
  description String
  badgeTypeId String
  badgeCost   Int
  supply      Int      // 0 = ilimitado
  active      Boolean  @default(true)
  creatorId   String
  txHash      String
  createdAt   DateTime @default(now())

  badgeType   BadgeType          @relation(fields: [badgeTypeId], references: [id])
  creator     User               @relation("RewardCreator", fields: [creatorId], references: [id])
  redemptions RewardRedemption[]
}

// Log de canjes de recompensas.
model RewardRedemption {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  txHash     String
  redeemedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// BIBLIOTECA
// ─────────────────────────────────────────────────────────────

enum LibraryItemType {
  BOOK
  BOARD_GAME
  VIDEO_GAME
  OTHER
}

enum LoanStatus {
  QUEUED
  RESERVED
  PICKED_UP
  RETURNED
  CANCELLED
}

// Cualquier elemento prestable de la biblioteca.
// tokenId = ID del ERC-1155 en LibraryManager.
// metadata (Json) guarda datos específicos por tipo:
//   BOOK:       { isbn, publisher, year, pages }
//   BOARD_GAME: { players, duration, ageRating }
//   VIDEO_GAME: { platform, genre }
model LibraryItem {
  id                String          @id @default(cuid())
  tokenId           Int             @unique  // ID en LibraryManager
  type              LibraryItemType @default(BOOK)
  title             String
  creator           String?         // autor, diseñador, desarrollador...
  description       String?
  coverUrl          String?
  category          String?
  physicalLocation  String?         // "2ª planta, Estantería 4B"
  physicalCondition String          @default("Bueno")
  totalCopies       Int
  metadata          Json?           // datos específicos del tipo
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())

  loans Loan[]
}

// Préstamo con cola automática. loanId = ID en LibraryManager.
// Flujo: QUEUED/RESERVED → PICKED_UP → RETURNED / CANCELLED.
model Loan {
  id               String     @id @default(cuid())
  loanId           Int        @unique  // ID en el contrato LibraryManager
  libraryItemId    String
  userId           String
  status           LoanStatus @default(QUEUED)
  requestTxHash    String?
  pickupTxHash     String?
  returnTxHash     String?
  requestDate      DateTime   @default(now())
  reservationDate  DateTime?
  pickupDate       DateTime?
  dueDate          DateTime?
  returnDate       DateTime?
  overdue          Boolean    @default(false)

  libraryItem LibraryItem @relation(fields: [libraryItemId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// SALAS DE ESTUDIO
// ─────────────────────────────────────────────────────────────

model Room {
  id          String    @id @default(cuid())
  roomId      Int       @unique        // ID on-chain en RoomBooking
  name        String                   // "Sala 1", "Sala de Estudio A"
  description String?
  location    String?                  // "Planta 2, ala norte"
  capacity    Int
  amenities   Json?                    // { "projector": true, "whiteboard": true }
  imageUrl    String?
  active      Boolean   @default(true)
  txHash      String
  createdAt   DateTime  @default(now())

  bookings    RoomBooking[]
}

model RoomBooking {
  id          String   @id @default(cuid())
  bookingId   Int      @unique         // ID on-chain en RoomBooking
  roomId      String
  userId      String
  date        DateTime                 // dia (sin hora, truncado a medianoche)
  startHour   Int                      // 0-23
  duration    Int                      // 1-4
  cancelled   Boolean  @default(false)
  txHash      String
  createdAt   DateTime @default(now())

  room        Room     @relation(fields: [roomId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([roomId, date])
  @@index([userId, date])
}

// ─────────────────────────────────────────────────────────────
// IMPRESIÓN
// ─────────────────────────────────────────────────────────────

model Printer {
  id        String  @id         // "IMP-BIB-01"
  name      String
  location  String              // "Biblioteca, planta 2"
  floor     String?
  active    Boolean @default(true)

  printLogs PrintLog[]
}

// Log de cada trabajo de impresión ejecutado.
model PrintLog {
  id           String   @id @default(cuid())
  userId       String
  filename     String               // nombre original del archivo subido
  pages        Int                  // total de caras impresas (= créditos consumidos)
  copies       Int      @default(1)
  printerId    String
  txHash       String               // prueba blockchain del pago de créditos
  creditsUsed  Int
  creditsAfter Int
  createdAt    DateTime @default(now())

  // Campos del simulador de impresión
  color         Boolean  @default(false)  // false = B/N, true = color
  duplex        Boolean  @default(false)  // impresión a doble cara
  orientation   String   @default("portrait")  // "portrait" | "landscape"
  paperSize     String   @default("A4")        // "A4" | "letter" | "A3"
  pageRangeFrom Int?                     // null = imprimir todas
  pageRangeTo   Int?                     // null = imprimir todas
  pagesPerSheet Int      @default(1)     // 1, 2 o 4 páginas por hoja
  filePages     Int      @default(1)     // páginas detectadas en el archivo original
  fileSize      Int      @default(0)     // tamaño del archivo en bytes
  filePath      String?                  // ruta temporal del archivo (se limpia)

  user    User    @relation(fields: [userId], references: [id])
  printer Printer @relation(fields: [printerId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// TIENDA
// ─────────────────────────────────────────────────────────────

enum OrderStatus {
  PAID
  DELIVERED
  RETURNED
}

// Producto de la tienda. productId = ID en CampusShop.
model Product {
  id          String   @id @default(cuid())
  productId   Int      @unique  // ID en el contrato CampusShop
  baseId      String?
  name        String
  color       String?
  variantLabel String?
  attributes  Json?
  description String?
  price       Int               // en ShopTokens
  stock       Int
  imageUrl    String?
  category    String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  base  ProductBase? @relation(fields: [baseId], references: [id])
  orders Order[]
  cartItems CartItem[]

  @@index([baseId])
}

model ProductBase {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  variants Product[]
}

// Pedido agrupado (batch). Un checkout del carrito = 1 batch con N artículos.
model OrderBatch {
  id           String   @id @default(cuid())
  batchId      Int      @unique  // ID en el contrato CampusShop
  userId       String
  totalPaid    Int
  txHash       String            // 1 solo txHash para toda la compra
  purchaseDate DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id])
  items Order[]                  // artículos individuales del pedido

  @@index([userId, purchaseDate])
}

// Artículo individual de un pedido. orderId = ID en CampusShop.
model Order {
  id           String      @id @default(cuid())
  orderId      Int         @unique  // ID en el contrato CampusShop
  userId       String
  productId    String
  batchId      String?             // nullable: compras sueltas (purchase) no tienen batch
  quantity     Int         @default(1)
  pricePaid    Int
  status       OrderStatus @default(PAID)
  txHash       String
  purchaseDate DateTime    @default(now())
  deliveryDate DateTime?
  returnDate   DateTime?

  user    User        @relation(fields: [userId], references: [id])
  product Product     @relation(fields: [productId], references: [id])
  batch   OrderBatch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

model CardTopupSimulation {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  cardBrand   String?
  cardLast4   String
  expiryMonth Int
  expiryYear  Int
  status      String
  txHash      String?
  errorReason String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model PaymentSimulationLog {
  id          String   @id @default(cuid())
  userId      String
  method      String
  amount      Int
  result      String
  cardLast4   String?
  txHash      String?
  errorReason String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
